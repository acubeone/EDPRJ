{
	"$jsonSchema": {
		"bsonType": "object",
		"required": ["cpf", "nome"],
		"properties": {
			"cpf": {
				"bsonType": "decimal",
				"description": "Must be a number, matches tipo_cpf NUMERIC(13)"
			},
			"nome": {
				"bsonType": "string",
				"maxLength": 100
			},
			"data_nascimento": {
				"bsonType": ["date", "null"]
			},
			"email": {
				"bsonType": ["array", "null"],
				"items": { "bsonType": "string" }
			},
			"telefone": {
				"bsonType": ["array", "null"],
				"items": { "bsonType": "string" }
			},
			"login": {
				"bsonType": ["string", "null"],
				"maxLength": 45
			},
			"senha": {
				"bsonType": ["string", "null"],
				"maxLength": 32
			}
		}
	}
}
